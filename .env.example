# Copy this file to `.env` (or `.env.local`) in the `app/` folder and fill in
# your Supabase project credentials. Without these, the app runs entirely on
# mock data (src/data/mockData.ts) and orders are stored in the browser's
# localStorage instead of a database. Never commit secrets.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional (for local Supabase CLI):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Development override: force the app to use local mock auth/data even if
# Supabase keys are present. Set to 'true' to enable simulation mode.
VITE_FORCE_MOCK_AUTH=false

# Mode VPS : active la validation serveur obligatoire des montants au checkout
# (POST /api/orders/validate) et l'initiation MoMo (POST /api/payments/momo).
# À activer uniquement quand le backend VPS est déployé derrière Nginx.
# Sans ce flag, l'app calcule les montants côté client (mode mock/dev).
VITE_USE_VPS_API=false
