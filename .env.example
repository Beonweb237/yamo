# Copy this file to `.env`, `.env.local`, or `.env.server` in the `app/` folder.
# VPS/Postgres is the backend target. Supabase is not part of this project.
# Never commit real secrets.

# Frontend
VITE_FORCE_MOCK_AUTH=false
VITE_USE_VPS_API=false
VITE_API_URL=
# Active les données de démonstration (avis, profils test) même hors mode dev.
# Mettre à true sur le VPS si vous voulez conserver les données de test.
VITE_ENABLE_DEMO_DATA=false

# Backend API VPS
API_PORT=3002
JWT_SECRET=change-me-with-a-long-random-secret

# PostgreSQL VPS/local
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=miamexpress
DB_USER=miamexpress
DB_PASSWORD=change-me
DB_SSL=false

# Reviews
# Keep false in production. If true, public review endpoints can include
# is_test=true rows only when the request also sends ?includeTest=true.
REVIEWS_INCLUDE_TEST_PUBLIC=false