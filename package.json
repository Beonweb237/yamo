{
  "name": "miamexpress",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "node scripts/seed.mjs",
    "seed:reviews": "node scripts/seed-review-examples.mjs",
    "seed:admin-demo": "node scripts/seed-admin-demo.mjs",
    "sync:review-stats": "node scripts/sync-restaurant-review-stats.mjs",
    "seed:test-profiles": "node scripts/seed-test-profiles.mjs",
    "verify:catalog": "node scripts/verify-catalog.mjs",
    "verify:points": "node scripts/verify-points.mjs",
    "verify:loyalty": "node scripts/verify-loyalty.mjs",
    "verify:integrity": "node scripts/verify-data-integrity.mjs",
    "gen:sitemap": "node scripts/gen-sitemap.mjs",
    "verify:i18n": "node scripts/verify-i18n.mjs",
    "verify:hooks": "node scripts/verify-hooks.mjs",
    "predeploy": "npm run verify:hooks && npm run verify:i18n && npm run build",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -SkipBuild",
    "deploy:dry": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -DryRun",
    "vps:shell": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command shell",
    "vps:status": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command status",
    "vps:logs": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command logs",
    "vps:restart": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command restart-services",
    "vps:disk": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command check-disk",
    "vps:process": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command check-process",
    "vps:update": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command update-app",
    "vps:backup": "powershell -ExecutionPolicy Bypass -File scripts/connect-vps.ps1 -Command backup-db"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/fr/",
      "/en/",
      "/fr/partenaires",
      "/en/partenaires",
      "/fr/livreurs",
      "/en/livreurs",
      "/fr/contact",
      "/en/contact"
    ],
    "crawl": false,
    "puppeteerExecutablePath": "C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.0",
    "i18next": "^26.3.6",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-i18next": "^17.0.10",
    "react-leaflet": "^5.0.0",
    "react-resizable-panels": "^4.2.2",
    "react-router": "^7.6.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "pg": "^8.22.0",
    "plugin-inspect-react-code": "^1.0.3",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "ts-morph": "^28.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}