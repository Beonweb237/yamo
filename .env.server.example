# ============================================================
# MiamExpress — Configuration VPS
# ============================================================
# Copier ce fichier en .env.server et remplir avec vos coordonnées

# --- Coordonnées VPS ---
VPS_HOST=vps-0943c5fc.vps.ovh.ca
VPS_USER=ubuntu
VPS_PATH=/home/ubuntu/miamexpress
VPS_SSH_KEY=$HOME/.ssh/id_ed25519

# --- Informations de sécurité ---
# ⚠️ NE PAS committer .env.server avec des vraies clés/mots de passe
# Garder ce fichier dans .gitignore

# --- Nom de domaine ---
DOMAIN=miamexpress.cm
DOMAIN_ALT=vps-0943c5fc.vps.ovh.ca

# --- Services backend ---
BACKEND_PORT=3002
MEDIA_API_PORT=3003

# --- Base de données (REQUIS) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=miamexpress
DB_USER=miamexpress
# ⚠️ OBLIGATOIRE — l'API refuse de démarrer sans. Ne jamais committer la vraie valeur.
DB_PASSWORD=

# --- Sécurité API (REQUIS) ---
# ⚠️ OBLIGATOIRE — secret de signature JWT. Générer une valeur aléatoire forte
# (ex: openssl rand -hex 48). Ne jamais committer la vraie valeur.
JWT_SECRET=

# --- Ports locaux pour tunneling SSH (optionnel) ---
LOCAL_SSH_PORT=2222
LOCAL_DB_PORT=5432
